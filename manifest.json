{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "__MSG_extensionName__",
  "version": "0.11.2",
  "description": "__MSG_extensionDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "journal-conference-rank-assistant@polarislight.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "searchTerms",
          "websiteContent"
        ]
      }
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://scholar.googleusercontent.com/*",
    "https://dblp.org/*",
    "https://*.dblp.org/*",
    "https://dblp.uni-trier.de/*",
    "https://*.dblp.uni-trier.de/*",
    "https://dblp.dagstuhl.de/*",
    "https://*.dblp.dagstuhl.de/*",
    "https://api.crossref.org/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "extension/popup/popup.html",
    "default_icon": {
      "16": "extension/icons/icon16.png",
      "32": "extension/icons/icon32.png",
      "48": "extension/icons/icon48.png"
    }
  },
  "options_page": "extension/popup/popup.html",
  "content_scripts": [
    {
      "matches": [
        "https://scholar.google.com/*",
        "https://scholar.googleusercontent.com/*",
        "https://www.semanticscholar.org/*",
        "https://semanticscholar.org/*",
        "https://arxiv.org/*",
        "https://openalex.org/*",
        "https://www.openalex.org/*",
        "https://pubmed.ncbi.nlm.nih.gov/*",
        "https://kns.cnki.net/*",
        "https://kns8.cnki.net/*",
        "https://s.wanfangdata.com.cn/*",
        "https://www.aminer.cn/*",
        "https://aminer.cn/*",
        "https://xueshu.baidu.com/*",
        "https://www.researchgate.net/*",
        "https://researchgate.net/*",
        "https://*.nature.com/*",
        "https://*.springer.com/*",
        "https://*.sciencedirect.com/*",
        "https://ieeexplore.ieee.org/*",
        "https://dl.acm.org/*",
        "https://*.wiley.com/*",
        "https://*.tandfonline.com/*",
        "https://journals.sagepub.com/*",
        "https://academic.oup.com/*",
        "https://*.cambridge.org/*",
        "https://*.mdpi.com/*",
        "https://*.frontiersin.org/*",
        "https://journals.plos.org/*",
        "https://*.biomedcentral.com/*",
        "https://*.emerald.com/*",
        "https://*.science.org/*",
        "https://*.cell.com/*",
        "https://journals.aps.org/*",
        "https://pubs.aip.org/*",
        "https://iopscience.iop.org/*",
        "https://pubs.acs.org/*",
        "https://pubs.rsc.org/*",
        "https://*.jamanetwork.com/*",
        "https://*.nejm.org/*",
        "https://*.thelancet.com/*",
        "https://*.bmj.com/*",
        "https://journals.lww.com/*",
        "https://*.karger.com/*",
        "https://*.degruyter.com/*",
        "https://*.hindawi.com/*",
        "https://*.annualreviews.org/*",
        "https://*.royalsocietypublishing.org/*",
        "https://epubs.siam.org/*",
        "https://journals.asm.org/*",
        "https://journals.physiology.org/*",
        "https://dblp.org/*",
        "https://*.dblp.org/*",
        "https://dblp.uni-trier.de/*",
        "https://*.dblp.uni-trier.de/*",
        "https://dblp.dagstuhl.de/*",
        "https://*.dblp.dagstuhl.de/*"
      ],
      "js": [
        "extension/lib/normalizer.js",
        "extension/lib/i18n.js",
        "extension/content/content-v7.js",
        "extension/content/filter-ui.js"
      ],
      "css": [
        "extension/content/badges.css",
        "extension/content/palettes.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "extension/background/background.js"
  },
  "icons": {
    "16": "extension/icons/icon16.png",
    "32": "extension/icons/icon32.png",
    "48": "extension/icons/icon48.png",
    "128": "extension/icons/icon128.png"
  }
}
